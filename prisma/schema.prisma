// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// YAKU V2.1 — Sistema Inteligente de Riego IoT + ML
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================
// 1. ROLES
// =============================================================
model roles {
  id          Int        @id @default(autoincrement())
  nombre      String     @unique @db.VarChar(50)
  descripcion String?

  usuarios    usuarios[]
}

// =============================================================
// 2. USUARIOS
// =============================================================
model usuarios {
  id             Int       @id @default(autoincrement())
  nombre         String    @db.VarChar(100)
  apellido       String?   @db.VarChar(100)
  correo         String    @unique @db.VarChar(100)
  contrasena     String    @db.VarChar(255)
  id_rol         Int
  telefono       String?   @db.VarChar(20)
  zona_horaria   String?   @default("America/Lima") @db.VarChar(50)
  verificado     Boolean   @default(false)
  estado         Boolean   @default(true)
  ultimo_acceso  DateTime?
  fecha_registro DateTime  @default(now())

  // Relaciones
  rol                          roles                          @relation(fields: [id_rol], references: [id])
  fuentes_agua                 fuentes_agua[]
  cultivos                     cultivos[]
  asignaciones_iot             asignaciones_iot[]
  umbrales_config              umbrales_config[]
  configuracion_control        configuracion_control[]
  modelos_ml_creados           modelos_ml[]                   @relation("ModeloCreadoPor")
  usuario_modelo               usuario_modelo?
  historial_modelos            historial_modelos[]
  predicciones_ml              predicciones_ml[]
  riego                        riego[]
  programacion_riego           programacion_riego[]
  reporte_consumo_agua         reporte_consumo_agua[]
  alertas_generadas            alertas[]                      @relation("AlertasGeneradas")
  alertas_resueltas            alertas[]                      @relation("AlertasResueltas")
  configuracion_notificaciones configuracion_notificaciones[]
  notificaciones               notificaciones[]
  logs_sistema                 logs_sistema[]

  @@index([correo])
  @@index([id_rol])
}

// =============================================================
// 3. DISPOSITIVOS
// =============================================================
model tipos_dispositivo {
  id          Int            @id @default(autoincrement())
  nombre      String         @db.VarChar(100)
  descripcion String?

  dispositivos dispositivos[]
}

model dispositivos {
  id                    Int               @id @default(autoincrement())
  id_tipo               Int
  nombre                String            @db.VarChar(100)
  mac_address           String?           @unique @db.VarChar(100)
  client_id_mqtt        String?           @unique @db.VarChar(100)
  topic_pub             String?           @db.VarChar(150)
  topic_sub             String?           @db.VarChar(150)
  ubicacion             String?           @db.VarChar(150)
  estado                String?           @default("activo") @db.VarChar(20)
  funcionamiento_activo Boolean           @default(true)
  ultimo_ping           DateTime?
  firmware_version      String?           @db.VarChar(20)
  fecha_registro        DateTime          @default(now())

  tipo                  tipos_dispositivo @relation(fields: [id_tipo], references: [id])
  asignaciones_iot      asignaciones_iot[]
}

// =============================================================
// 4. CATÁLOGO DE MÉTRICAS
// =============================================================
model tipos_metrica {
  id             Int       @id @default(autoincrement())
  codigo         String    @unique @db.VarChar(50)
  nombre         String    @db.VarChar(100)
  unidad         String    @db.VarChar(20)
  descripcion    String?
  fecha_registro DateTime  @default(now())

  tipos_componente             tipos_componente[]
  umbrales_planta              umbrales_planta[]
  umbrales_config              umbrales_config[]
  alertas                      alertas[]
}

// =============================================================
// 5. COMPONENTES E INVENTARIO FÍSICO
// =============================================================
model tipos_componente {
  id              Int            @id @default(autoincrement())
  nombre_modelo   String         @unique @db.VarChar(100)
  categoria       String         @db.VarChar(30)
  id_tipo_metrica Int?
  descripcion     String?

  tipo_metrica    tipos_metrica? @relation(fields: [id_tipo_metrica], references: [id])
  componentes     componentes[]
}

model componentes {
  id                 Int              @id @default(autoincrement())
  id_tipo_componente Int
  numero_serie       String?          @unique @db.VarChar(100)
  estado             String?          @default("activo") @db.VarChar(20)
  fecha_registro     DateTime         @default(now())

  tipo_componente    tipos_componente @relation(fields: [id_tipo_componente], references: [id], onDelete: Cascade)
  asignaciones_iot   asignaciones_iot[]
}

// =============================================================
// 6. FUENTES DE AGUA
// Nota: el CHECK constraint (tipo='tanque' requiere capacidad y
// altura) no es soportado por Prisma. Aplicar a nivel de app.
// =============================================================
model fuentes_agua {
  id                  Int       @id @default(autoincrement())
  id_usuario          Int
  nombre              String    @db.VarChar(100)
  tipo                String    @db.VarChar(30)
  capacidad_litros    Decimal?  @db.Decimal(10, 2)
  altura_tanque_cm    Decimal?  @db.Decimal(6, 2)
  altura_seguridad_cm Decimal?  @db.Decimal(6, 2)
  activo              Boolean   @default(true)
  fecha_registro      DateTime  @default(now())

  usuario             usuarios         @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
  cultivos            cultivos[]
  asignaciones_iot    asignaciones_iot[]
}

// =============================================================
// 7. PLANTAS Y CULTIVOS
// =============================================================
model plantas {
  id          Int               @id @default(autoincrement())
  nombre      String            @db.VarChar(100)
  tipo        String?           @db.VarChar(50)
  descripcion String?

  umbrales_planta umbrales_planta[]
  cultivos        cultivos[]
}

model umbrales_planta {
  id              Int           @id @default(autoincrement())
  id_planta       Int
  id_tipo_metrica Int
  valor_minimo    Decimal?      @db.Decimal(10, 2)
  valor_maximo    Decimal?      @db.Decimal(10, 2)

  planta          plantas       @relation(fields: [id_planta], references: [id], onDelete: Cascade)
  tipo_metrica    tipos_metrica @relation(fields: [id_tipo_metrica], references: [id])

  @@unique([id_planta, id_tipo_metrica])
}

model regiones {
  id         Int          @id @default(autoincrement())
  nombre     String       @unique @db.VarChar(100)

  provincias provincias[]
}

model provincias {
  id        Int         @id @default(autoincrement())
  id_region Int
  nombre    String      @db.VarChar(100)

  region    regiones    @relation(fields: [id_region], references: [id], onDelete: Cascade)
  distritos distritos[]

  @@unique([id_region, nombre])
}

model distritos {
  id           Int        @id @default(autoincrement())
  id_provincia Int
  nombre       String     @db.VarChar(100)

  provincia    provincias @relation(fields: [id_provincia], references: [id], onDelete: Cascade)
  cultivos     cultivos[]

  @@unique([id_provincia, nombre])
}

model cultivos {
  id                Int           @id @default(autoincrement())
  id_usuario        Int
  id_planta         Int?
  id_fuente_agua    Int?
  id_distrito       Int?
  lugar             String?       @db.VarChar(255)
  nombre_planta     String        @db.VarChar(100)
  etapa_crecimiento String?       @db.VarChar(50)
  area_m2           Decimal?      @db.Decimal(10, 2)
  fecha_siembra     DateTime?     @db.Date
  estado            String?       @default("activo") @db.VarChar(20)
  fecha_registro    DateTime      @default(now())

  usuario           usuarios      @relation(fields: [id_usuario], references: [id])
  planta            plantas?      @relation(fields: [id_planta], references: [id])
  fuente_agua       fuentes_agua? @relation(fields: [id_fuente_agua], references: [id], onDelete: SetNull)
  distrito          distritos?    @relation(fields: [id_distrito], references: [id], onDelete: SetNull)

  asignaciones_iot      asignaciones_iot[]
  umbrales_config       umbrales_config[]
  configuracion_control configuracion_control[]
  predicciones_ml       predicciones_ml[]
  reporte_consumo_agua  reporte_consumo_agua[]

  @@index([id_usuario])
}

// =============================================================
// 8. ASIGNACIONES IOT (tabla pivote central)
// Nota: @@unique incluye campos nullable (id_componente,
// id_cultivo). PostgreSQL trata NULL≠NULL en UNIQUE, por lo que
// varias filas con NULL en esos campos no generan conflicto.
// =============================================================
model asignaciones_iot {
  id             Int       @id @default(autoincrement())
  id_usuario     Int
  id_dispositivo Int
  id_componente  Int?
  id_fuente_agua Int?
  id_cultivo     Int?
  pin_gpio       Int?
  activo         Boolean   @default(true)
  fecha_registro DateTime  @default(now())

  usuario        usuarios         @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
  dispositivo    dispositivos     @relation(fields: [id_dispositivo], references: [id], onDelete: Cascade)
  componente     componentes?     @relation(fields: [id_componente], references: [id], onDelete: SetNull)
  fuente_agua    fuentes_agua?    @relation(fields: [id_fuente_agua], references: [id], onDelete: SetNull)
  cultivo        cultivos?        @relation(fields: [id_cultivo], references: [id], onDelete: SetNull)

  configuracion_tanque  configuracion_tanque?
  humedad_suelo         humedad_suelo[]
  humedad_ambiente      humedad_ambiente[]
  temperatura_ambiente  temperatura_ambiente[]
  temperatura_suelo     temperatura_suelo[]
  telemetria_tanque     telemetria_tanque[]
  lecturas_bateria      lecturas_bateria[]
  riego                 riego[]
  programacion_riego    programacion_riego[]
  alertas               alertas[]

  @@unique([id_usuario, id_dispositivo, id_componente, id_cultivo])
  @@index([id_usuario])
  @@index([id_dispositivo])
  @@index([id_cultivo])
}

// =============================================================
// 9. CONFIGURACIÓN DEL TANQUE (estado en tiempo real del actuador)
// PK = id_asignacion → relación 1-a-1 con asignaciones_iot
// =============================================================
model configuracion_tanque {
  id_asignacion   Int       @id
  valvula_abierta Boolean   @default(false)
  bomba_encendida Boolean   @default(false)
  actualizado_en  DateTime  @default(now())

  asignacion      asignaciones_iot @relation(fields: [id_asignacion], references: [id], onDelete: Cascade)
}

// =============================================================
// 10. LECTURAS DE TELEMETRÍA
// Todas usan BIGSERIAL → BigInt en Prisma
// Vinculadas a asignaciones_iot (no a sensores directos)
// =============================================================

// 10.1 Humedad del suelo (sensor capacitivo)
model humedad_suelo {
  id            BigInt    @id @default(autoincrement())
  id_asignacion Int
  valor         Decimal?  @db.Decimal(10, 2)
  porcentaje    Decimal?  @db.Decimal(10, 2)
  ema           Decimal?  @db.Decimal(10, 2)
  desviacion    Decimal?  @db.Decimal(8, 3)
  valido        Boolean   @default(true)
  fecha         DateTime  @default(now())

  asignacion    asignaciones_iot @relation(fields: [id_asignacion], references: [id], onDelete: Cascade)

  @@index([id_asignacion])
  @@index([fecha(sort: Desc)])
}

// 10.2 Humedad ambiente (DHT22)
model humedad_ambiente {
  id            BigInt    @id @default(autoincrement())
  id_asignacion Int
  valor         Decimal?  @db.Decimal(10, 2)
  porcentaje    Decimal?  @db.Decimal(10, 2)
  ema           Decimal?  @db.Decimal(10, 2)
  desviacion    Decimal?  @db.Decimal(8, 3)
  valido        Boolean   @default(true)
  fecha         DateTime  @default(now())

  asignacion    asignaciones_iot @relation(fields: [id_asignacion], references: [id], onDelete: Cascade)

  @@index([id_asignacion])
  @@index([fecha(sort: Desc)])
}

// 10.3 Temperatura ambiente (DHT22)
model temperatura_ambiente {
  id            BigInt    @id @default(autoincrement())
  id_asignacion Int
  valor         Decimal?  @db.Decimal(10, 2)
  temperatura   Decimal?  @db.Decimal(10, 2)
  ema           Decimal?  @db.Decimal(10, 2)
  desviacion    Decimal?  @db.Decimal(8, 3)
  valido        Boolean   @default(true)
  fecha         DateTime  @default(now())

  asignacion    asignaciones_iot @relation(fields: [id_asignacion], references: [id], onDelete: Cascade)

  @@index([id_asignacion])
  @@index([fecha(sort: Desc)])
}

// 10.4 Temperatura suelo (DS18B20)
model temperatura_suelo {
  id            BigInt    @id @default(autoincrement())
  id_asignacion Int
  valor         Decimal?  @db.Decimal(10, 2)
  temperatura   Decimal?  @db.Decimal(10, 2)
  ema           Decimal?  @db.Decimal(10, 2)
  desviacion    Decimal?  @db.Decimal(8, 3)
  valido        Boolean   @default(true)
  fecha         DateTime  @default(now())

  asignacion    asignaciones_iot @relation(fields: [id_asignacion], references: [id], onDelete: Cascade)

  @@index([id_asignacion])
  @@index([fecha(sort: Desc)])
}

// 10.5 Telemetría tanque (HC-SR04 + estado bomba/válvula en tiempo real)
model telemetria_tanque {
  id               BigInt    @id @default(autoincrement())
  id_asignacion    Int
  distancia_cm     Decimal   @db.Decimal(10, 2)
  nivel_agua_cm    Decimal?  @db.Decimal(10, 2)
  porcentaje_nivel Decimal?  @db.Decimal(10, 2)
  estado_nivel     String?   @db.VarChar(20)
  valvula_abierta  Boolean   @default(false)
  bomba_encendida  Boolean   @default(false)
  fuente_control   String?   @db.VarChar(30)
  fecha            DateTime  @default(now())

  asignacion       asignaciones_iot @relation(fields: [id_asignacion], references: [id], onDelete: Cascade)

  @@index([id_asignacion])
  @@index([fecha(sort: Desc)])
  @@index([estado_nivel])
}

// 10.6 Lecturas de batería (opcional, cuando ESP32 opera con batería)
model lecturas_bateria {
  id            BigInt    @id @default(autoincrement())
  id_asignacion Int
  porcentaje    Decimal   @db.Decimal(5, 2)
  voltaje       Decimal?  @db.Decimal(4, 2)
  fecha         DateTime  @default(now())

  asignacion    asignaciones_iot @relation(fields: [id_asignacion], references: [id], onDelete: Cascade)

  @@index([id_asignacion])
  @@index([fecha(sort: Desc)])
}

// =============================================================
// 11. UMBRALES Y CONFIGURACIÓN DE CONTROL
// Nota: @@unique sobre campos nullable sigue semántica
// PostgreSQL (NULL ≠ NULL), correcto para ambas tablas.
// =============================================================
model umbrales_config {
  id              Int           @id @default(autoincrement())
  id_usuario      Int
  id_cultivo      Int?
  id_tipo_metrica Int
  valor_minimo    Decimal?      @db.Decimal(10, 2)
  valor_maximo    Decimal?      @db.Decimal(10, 2)
  actualizado_en  DateTime      @default(now())

  usuario         usuarios      @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
  cultivo         cultivos?     @relation(fields: [id_cultivo], references: [id], onDelete: Cascade)
  tipo_metrica    tipos_metrica @relation(fields: [id_tipo_metrica], references: [id])

  @@unique([id_usuario, id_cultivo, id_tipo_metrica])
}

model configuracion_control {
  id                     Int       @id @default(autoincrement())
  id_usuario             Int
  id_cultivo             Int?
  duracion_riego_max_seg Int       @default(1800)
  confianza_ml_minima    Decimal   @default(0.70) @db.Decimal(4, 3)
  actualizado_en         DateTime  @default(now())

  usuario                usuarios  @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
  cultivo                cultivos? @relation(fields: [id_cultivo], references: [id], onDelete: Cascade)

  @@unique([id_usuario, id_cultivo])
}

// =============================================================
// 12. MODELOS ML Y PREDICCIONES
// =============================================================
model modelos_ml {
  id                  Int       @id @default(autoincrement())
  nombre_modelo       String    @db.VarChar(100)
  algoritmo           String    @db.VarChar(50)
  descripcion         String?
  ruta_archivo        String?   @db.VarChar(255)
  precision_modelo    Decimal?  @db.Decimal(5, 2)
  precision_score     Decimal?  @db.Decimal(5, 4)
  recall_score        Decimal?  @db.Decimal(5, 4)
  f1_score            Decimal?  @db.Decimal(5, 4)
  version             String?   @default("1.0.0") @db.VarChar(20)
  es_default          Boolean   @default(false)
  estado              String?   @default("activo") @db.VarChar(20)
  creado_por          Int?
  fecha_registro      DateTime  @default(now())
  fecha_entrenamiento DateTime?

  creador             usuarios?           @relation("ModeloCreadoPor", fields: [creado_por], references: [id])
  usuario_modelo      usuario_modelo[]
  historial_modelos   historial_modelos[]
  predicciones_ml     predicciones_ml[]
  riego               riego[]
}

// Un modelo activo por usuario (UNIQUE en id_usuario)
model usuario_modelo {
  id               Int       @id @default(autoincrement())
  id_usuario       Int       @unique
  id_modelo        Int
  activo           Boolean   @default(true)
  fecha_asignacion DateTime  @default(now())

  usuario          usuarios   @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
  modelo           modelos_ml @relation(fields: [id_modelo], references: [id])
}

model historial_modelos {
  id          Int        @id @default(autoincrement())
  id_usuario  Int?
  id_modelo   Int?
  accion      String?    @db.VarChar(50)
  descripcion String?
  fecha       DateTime   @default(now())

  usuario     usuarios?   @relation(fields: [id_usuario], references: [id])
  modelo      modelos_ml? @relation(fields: [id_modelo], references: [id])
}

// variables_entrada → JSONB en PostgreSQL → Json en Prisma
model predicciones_ml {
  id               BigInt    @id @default(autoincrement())
  id_usuario       Int
  id_modelo        Int
  id_cultivo       Int?
  variables_entrada Json
  recomendacion    String?   @db.VarChar(50)
  probabilidad     Decimal?  @db.Decimal(5, 2)
  accion_ejecutada Boolean?
  fuente_accion    String?   @db.VarChar(30)
  fecha            DateTime  @default(now())

  usuario          usuarios    @relation(fields: [id_usuario], references: [id])
  modelo           modelos_ml  @relation(fields: [id_modelo], references: [id])
  cultivo          cultivos?   @relation(fields: [id_cultivo], references: [id])
  riego            riego[]

  @@index([id_usuario])
  @@index([id_modelo])
  @@index([fecha(sort: Desc)])
}

// =============================================================
// 13. RIEGO Y PROGRAMACIÓN
// =============================================================
model riego {
  id                   BigInt    @id @default(autoincrement())
  id_asignacion        Int
  id_usuario           Int?
  id_modelo            Int?
  id_prediccion        BigInt?
  tipo_riego           String    @db.VarChar(20)
  duracion_segundos    Int?
  cantidad_agua_litros Decimal?  @db.Decimal(10, 2)
  motivo_cierre        String?   @db.VarChar(50)
  estado               Boolean   @default(false)
  fecha                DateTime  @default(now())

  asignacion           asignaciones_iot  @relation(fields: [id_asignacion], references: [id], onDelete: Cascade)
  usuario              usuarios?         @relation(fields: [id_usuario], references: [id])
  modelo               modelos_ml?       @relation(fields: [id_modelo], references: [id])
  prediccion           predicciones_ml?  @relation(fields: [id_prediccion], references: [id])

  @@index([id_asignacion])
  @@index([id_usuario])
  @@index([fecha(sort: Desc)])
}

// hora_inicio → TIME en PostgreSQL → DateTime @db.Time(0) en Prisma
model plantillas_riego {
  id           Int       @id @default(autoincrement())
  nombre       String    @unique @db.VarChar(100)
  lunes        Boolean   @default(false)
  martes       Boolean   @default(false)
  miercoles    Boolean   @default(false)
  jueves       Boolean   @default(false)
  viernes      Boolean   @default(false)
  sabado       Boolean   @default(false)
  domingo      Boolean   @default(false)
  hora_inicio  DateTime  @db.Time(0)
  duracion_seg Int       @default(300)

  programacion_riego programacion_riego[]
}

model programacion_riego {
  id               Int       @id @default(autoincrement())
  id_asignacion    Int
  id_usuario       Int
  id_plantilla     Int?
  nombre           String?   @db.VarChar(100)
  lunes            Boolean   @default(false)
  martes           Boolean   @default(false)
  miercoles        Boolean   @default(false)
  jueves           Boolean   @default(false)
  viernes          Boolean   @default(false)
  sabado           Boolean   @default(false)
  domingo          Boolean   @default(false)
  hora_inicio      DateTime  @db.Time(0)
  duracion_seg     Int       @default(300)
  activo           Boolean   @default(true)
  ultima_ejecucion DateTime?
  fecha_registro   DateTime  @default(now())

  asignacion       asignaciones_iot  @relation(fields: [id_asignacion], references: [id], onDelete: Cascade)
  usuario          usuarios          @relation(fields: [id_usuario], references: [id])
  plantilla        plantillas_riego? @relation(fields: [id_plantilla], references: [id], onDelete: SetNull)

  @@index([id_asignacion])
  @@index([id_usuario])
}

// =============================================================
// 14. REPORTE DE CONSUMO DE AGUA
// =============================================================
model reporte_consumo_agua {
  id                      Int       @id @default(autoincrement())
  id_usuario              Int
  id_cultivo              Int?
  periodo_inicio          DateTime  @db.Date
  periodo_fin             DateTime  @db.Date
  consumo_total_litros    Decimal?  @db.Decimal(12, 3)
  consumo_manual_litros   Decimal?  @db.Decimal(12, 3)
  reduccion_porcentaje    Decimal?  @db.Decimal(5, 2)
  riegos_automaticos      Int?
  riegos_manuales         Int?
  riegos_programados      Int?
  duracion_total_segundos Int?
  generado_en             DateTime  @default(now())

  usuario                 usuarios  @relation(fields: [id_usuario], references: [id])
  cultivo                 cultivos? @relation(fields: [id_cultivo], references: [id])

  @@index([id_usuario])
  @@index([periodo_inicio, periodo_fin])
}

// =============================================================
// 15. ALERTAS Y NOTIFICACIONES
// alertas tiene dos FK a usuarios (generada por / resuelta por)
// → se nombran las relaciones para evitar ambigüedad
// =============================================================
model tipos_alerta {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique @db.VarChar(50)
  nombre      String    @db.VarChar(100)
  descripcion String?
  severidad   String    @db.VarChar(20)
  activo      Boolean   @default(true)

  alertas                      alertas[]
  configuracion_notificaciones configuracion_notificaciones[]
}

model alertas {
  id              BigInt    @id @default(autoincrement())
  id_usuario      Int
  id_asignacion   Int?
  id_tipo_alerta  Int
  id_tipo_metrica Int?
  mensaje         String
  prioridad       String?   @db.VarChar(20)
  valor_detectado Decimal?  @db.Decimal(10, 2)
  umbral          Decimal?  @db.Decimal(10, 2)
  estado          String?   @default("pendiente") @db.VarChar(20)
  resuelta_por    Int?
  resuelta_en     DateTime?
  comentario      String?
  fecha           DateTime  @default(now())

  // id_usuario: quién recibe la alerta
  usuario         usuarios          @relation("AlertasGeneradas", fields: [id_usuario], references: [id])
  // resuelta_por: quién la resolvió (puede ser distinto)
  resuelto_por    usuarios?         @relation("AlertasResueltas", fields: [resuelta_por], references: [id])
  asignacion      asignaciones_iot? @relation(fields: [id_asignacion], references: [id], onDelete: Cascade)
  tipo_alerta     tipos_alerta      @relation(fields: [id_tipo_alerta], references: [id])
  tipo_metrica    tipos_metrica?    @relation(fields: [id_tipo_metrica], references: [id])
  notificaciones  notificaciones[]

  @@index([id_usuario])
  @@index([id_asignacion])
  @@index([id_tipo_alerta])
  @@index([estado])
  @@index([fecha(sort: Desc)])
}

model configuracion_notificaciones {
  id              Int          @id @default(autoincrement())
  id_usuario      Int
  id_tipo_alerta  Int
  activo          Boolean      @default(true)
  canal_email     Boolean      @default(true)
  canal_dashboard Boolean      @default(true)

  usuario         usuarios     @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
  tipo_alerta     tipos_alerta @relation(fields: [id_tipo_alerta], references: [id])

  @@unique([id_usuario, id_tipo_alerta])
}

model notificaciones {
  id         BigInt    @id @default(autoincrement())
  id_alerta  BigInt
  id_usuario Int
  canal      String    @db.VarChar(20)
  asunto     String?   @db.VarChar(200)
  mensaje    String?
  enviado    Boolean   @default(false)
  enviado_en DateTime?
  error      String?

  alerta     alertas  @relation(fields: [id_alerta], references: [id])
  usuario    usuarios @relation(fields: [id_usuario], references: [id])

  @@index([id_alerta])
  @@index([id_usuario])
  @@index([enviado])
}

// =============================================================
// 16. AUDITORÍA Y LOGS
// ip_acceso → INET en PostgreSQL → String @db.Inet en Prisma
// =============================================================
model logs_sistema {
  id          BigInt    @id @default(autoincrement())
  id_usuario  Int?
  accion      String    @db.VarChar(100)
  modulo      String?   @db.VarChar(50)
  descripcion String?
  ip_acceso   String?   @db.Inet
  fecha       DateTime  @default(now())

  usuario     usuarios? @relation(fields: [id_usuario], references: [id])

  @@index([id_usuario])
  @@index([fecha(sort: Desc)])
}